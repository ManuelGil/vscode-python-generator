{
	"name": "vscode-python-generator",
	"displayName": "Python File Generator for FastAPI & CLI",
	"description": "Python file generator and FastAPI generator with reusable code templates for CLI scaffolding and boilerplate reduction.",
	"version": "1.0.0",
	"icon": "icon.png",
	"pricing": "Free",
	"license": "MIT",
	"publisher": "imgildev",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"vscode": "^1.102.0",
		"node": ">=22"
	},
	"categories": [
		"Snippets",
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"python",
		"fastapi",
		"code generator",
		"templates",
		"scaffold",
		"cli",
		"boilerplate",
		"productivity",
		"developer tools",
		"python file generator",
		"fastapi generator",
		"code templates",
		"scaffolding",
		"project scaffolding",
		"vscode extension"
	],
	"homepage": "https://github.com/ManuelGil/vscode-python-generator",
	"repository": {
		"type": "git",
		"url": "https://github.com/ManuelGil/vscode-python-generator"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-python-generator/issues"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"l10n": "./l10n",
	"files": [
		"out",
		"templates",
		"package*.json",
		"README.md",
		"LICENSE",
		"icon.png",
		"schemas",
		"l10n"
	],
	"contributes": {
		"configuration": {
			"title": "%pythonGenerator.configuration.title%",
			"properties": {
				"pythonGenerator.enable": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%pythonGenerator.enable%"
				},
				"pythonGenerator.files.skipFolderConfirmation": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%pythonGenerator.files.skipFolderConfirmation%"
				},
				"pythonGenerator.files.includeTypeInFileName": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%pythonGenerator.files.includeTypeInFileName%"
				},
				"pythonGenerator.formatting.useSingleQuotes": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%pythonGenerator.formatting.useSingleQuotes%"
				},
				"pythonGenerator.formatting.excludeSemiColonAtEndOfLine": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%pythonGenerator.formatting.excludeSemiColonAtEndOfLine%"
				},
				"pythonGenerator.formatting.endOfLine": {
					"type": "string",
					"default": "lf",
					"enum": [
						"crlf",
						"lf"
					],
					"enumDescriptions": [
						"%pythonGenerator.lineEnding.crlf%",
						"%pythonGenerator.lineEnding.lf%"
					],
					"scope": "resource",
					"description": "%pythonGenerator.formatting.endOfLine%"
				},
				"pythonGenerator.formatting.useStrict": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%pythonGenerator.formatting.useStrict%"
				},
				"pythonGenerator.formatting.headerCommentTemplate": {
					"type": "array",
					"default": [],
					"scope": "resource",
					"description": "%pythonGenerator.formatting.headerCommentTemplate%"
				},
				"pythonGenerator.formatting.insertFinalNewline": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%pythonGenerator.formatting.insertFinalNewline%"
				},
				"pythonGenerator.project.author": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"description": "%pythonGenerator.project.author%"
				},
				"pythonGenerator.project.owner": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"description": "%pythonGenerator.project.owner%"
				},
				"pythonGenerator.project.maintainers": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"description": "%pythonGenerator.project.maintainers%"
				},
				"pythonGenerator.project.license": {
					"type": "string",
					"default": "MIT",
					"scope": "resource",
					"description": "%pythonGenerator.project.license%"
				},
				"pythonGenerator.project.version": {
					"type": "string",
					"default": "1.0.0",
					"scope": "resource",
					"description": "%pythonGenerator.project.version%"
				},
				"pythonGenerator.templates.customTemplates": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string",
								"description": "%pythonGenerator.template.name%"
							},
							"description": {
								"type": "string",
								"description": "%pythonGenerator.template.description%"
							},
							"type": {
								"type": "string",
								"description": "%pythonGenerator.template.type%"
							},
							"template": {
								"type": "array",
								"description": "%pythonGenerator.template.content%"
							}
						}
					},
					"default": [],
					"scope": "resource",
					"description": "%pythonGenerator.templates.customTemplates%"
				}
			}
		},
		"commands": [
			{
				"command": "pythonGenerator.changeWorkspace",
				"title": "%pythonGenerator.changeWorkspace%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generate",
				"title": "%pythonGenerator.generate%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateCustomTemplate",
				"title": "%pythonGenerator.generateCustomTemplate%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generatePythonScript",
				"title": "%pythonGenerator.generatePythonScript%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generatePythonModule",
				"title": "%pythonGenerator.generatePythonModule%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateCliTool",
				"title": "%pythonGenerator.generateCliTool%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateService",
				"title": "%pythonGenerator.generateService%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateRepository",
				"title": "%pythonGenerator.generateRepository%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateDTO",
				"title": "%pythonGenerator.generateDTO%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateTest",
				"title": "%pythonGenerator.generateTest%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateLogger",
				"title": "%pythonGenerator.generateLogger%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateFastAPIRoute",
				"title": "%pythonGenerator.generateFastAPIRoute%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateFastApiFeature",
				"title": "%pythonGenerator.generateFastApiFeature%",
				"category": "%pythonGenerator.command.category%"
			},
			{
				"command": "pythonGenerator.generateDjangoModel",
				"title": "%pythonGenerator.generateDjangoModel%",
				"category": "%pythonGenerator.command.category%"
			}
		],
		"submenus": [
			{
				"id": "pythonGenerator.folder.submenu",
				"label": "%pythonGenerator.submenu.label%"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "pythonGenerator.changeWorkspace",
					"group": "0_workspace@1"
				},
				{
					"command": "pythonGenerator.generate",
					"group": "0_primary@1",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateFastApiFeature",
					"group": "2_features@1",
					"when": "pythonGenerator.isEnabled && pythonGenerator.hasFastApi"
				},
				{
					"command": "pythonGenerator.generateCustomTemplate",
					"group": "1_common@1",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generatePythonScript",
					"group": "1_common@2",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generatePythonModule",
					"group": "1_common@3",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateCliTool",
					"group": "1_common@4",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateService",
					"group": "1_common@5",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateRepository",
					"group": "1_common@6",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateDTO",
					"group": "1_common@7",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateTest",
					"group": "1_common@8",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateLogger",
					"group": "1_common@9",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateFastAPIRoute",
					"group": "2_features@2",
					"when": "pythonGenerator.isEnabled && pythonGenerator.hasFastApi"
				},
				{
					"command": "pythonGenerator.generateDjangoModel",
					"group": "2_features@3",
					"when": "pythonGenerator.isEnabled && pythonGenerator.hasFramework"
				}
			],
			"explorer/context": [
				{
					"submenu": "pythonGenerator.folder.submenu",
					"group": "2_workspace",
					"when": "explorerViewletFocus && explorerResourceIsFolder && !explorerResourceIsRoot && pythonGenerator.isEnabled"
				}
			],
			"pythonGenerator.folder.submenu": [
				{
					"command": "pythonGenerator.generate",
					"group": "0_primary@1",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateFastApiFeature",
					"group": "2_features@1",
					"when": "pythonGenerator.isEnabled && pythonGenerator.hasFastApi"
				},
				{
					"command": "pythonGenerator.generateCustomTemplate",
					"group": "1_generics@1",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generatePythonScript",
					"group": "1_generics@2",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generatePythonModule",
					"group": "1_generics@3",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateCliTool",
					"group": "1_generics@4",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateService",
					"group": "1_generics@5",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateRepository",
					"group": "1_generics@6",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateDTO",
					"group": "1_generics@7",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateTest",
					"group": "1_generics@8",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateLogger",
					"group": "1_generics@9",
					"when": "pythonGenerator.isEnabled"
				},
				{
					"command": "pythonGenerator.generateFastAPIRoute",
					"group": "2_features@2",
					"when": "pythonGenerator.isEnabled && pythonGenerator.hasFastApi"
				},
				{
					"command": "pythonGenerator.generateDjangoModel",
					"group": "2_features@3",
					"when": "pythonGenerator.isEnabled && pythonGenerator.hasFramework"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": ".vscode/settings.json",
				"url": "./schemas/config.schema.json"
			},
			{
				"fileMatch": [
					"templates/*.json"
				],
				"url": "./schemas/template.schema.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm compile",
		"typecheck": "tsc --noEmit -p ./",
		"compile": "pnpm typecheck && rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=out/extension.js --minify",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm compile && pnpm lint",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "vscode-test",
		"l10n:check": "node scripts/check-l10n.js",
		"nls:check": "node scripts/check-nls.js",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/mocha": "^10.0.10",
		"@types/mustache": "^4.2.6",
		"@types/node": "^22.19.17",
		"@types/vscode": "^1.118.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.28.0",
		"fast-glob": "^3.3.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"ignore": "^5.3.2",
		"mustache": "^4.2.0",
		"vscode-marketplace-client": "^1.2.1",
		"zod": "^4.4.1"
	},
	"pnpm": {
		"overrides": {
			"axios": "^1.13.5"
		},
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
