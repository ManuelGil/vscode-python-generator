{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"properties": {
		"pythonGenerator.enable": {
			"type": "boolean",
			"default": true,
			"scope": "resource",
			"description": "Enable or disable Python File Generator"
		},
		"pythonGenerator.files.skipFolderConfirmation": {
			"type": "boolean",
			"default": true,
			"scope": "resource",
			"description": "Skip destination folder confirmation when generating files"
		},
		"pythonGenerator.files.includeTypeInFileName": {
			"type": "boolean",
			"default": false,
			"scope": "resource",
			"description": "Include type in file name"
		},
		"pythonGenerator.formatting.useSingleQuotes": {
			"type": "boolean",
			"default": true,
			"scope": "resource",
			"description": "Use single quotes instead of double quotes"
		},
		"pythonGenerator.formatting.excludeSemiColonAtEndOfLine": {
			"type": "boolean",
			"default": false,
			"scope": "resource",
			"description": "Exclude semicolon at the end of line"
		},
		"pythonGenerator.formatting.endOfLine": {
			"type": "string",
			"default": "lf",
			"enum": ["crlf", "lf"],
			"enumDescriptions": ["Windows (CRLF)", "Unix (LF)"],
			"scope": "resource",
			"description": "End of line character"
		},
		"pythonGenerator.formatting.useStrict": {
			"type": "boolean",
			"default": false,
			"scope": "resource",
			"description": "Use strict mode"
		},
		"pythonGenerator.formatting.headerCommentTemplate": {
			"type": "array",
			"default": [],
			"scope": "resource",
			"description": "Header comment template"
		},
		"pythonGenerator.formatting.insertFinalNewline": {
			"type": "boolean",
			"default": true,
			"scope": "resource",
			"description": "Insert final newline"
		},
		"pythonGenerator.project.author": {
			"type": "string",
			"default": "",
			"scope": "resource",
			"description": "Project author"
		},
		"pythonGenerator.project.owner": {
			"type": "string",
			"default": "",
			"scope": "resource",
			"description": "Project owner"
		},
		"pythonGenerator.project.maintainers": {
			"type": "string",
			"default": "",
			"scope": "resource",
			"description": "Project maintainers"
		},
		"pythonGenerator.project.license": {
			"type": "string",
			"default": "MIT",
			"scope": "resource",
			"description": "Project license"
		},
		"pythonGenerator.project.version": {
			"type": "string",
			"default": "1.0.0",
			"scope": "resource",
			"description": "Project version"
		},
		"pythonGenerator.templates.customTemplates": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"description": "Name of the template"
					},
					"description": {
						"type": "string",
						"description": "Description of the template"
					},
					"type": {
						"type": "string",
						"description": "The template type"
					},
					"template": {
						"type": "array",
						"description": "The template content"
					}
				}
			},
			"default": [],
			"scope": "resource",
			"description": "Custom templates"
		}
	}
}
