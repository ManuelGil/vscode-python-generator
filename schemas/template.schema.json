{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Python Generator Template",
	"type": "object",
	"required": ["id", "template"],
	"properties": {
		"id": {
			"type": "string"
		},
		"template": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"kind": {
			"type": "string",
			"enum": ["file", "multi"]
		},
		"files": {
			"type": "array",
			"items": {
				"type": "string"
			}
		}
	}
}
