{
	"id": "python.domain.service",
	"name": "Python Service",
	"description": "Application service / use case class",
	"category": "file",
	"subcategory": "domain",
	"tags": ["python", "service", "use-case"],
	"framework": "none",
	"language": "python",
	"kind": "file",
	"multiFile": false,
	"type": "service",
	"output": {
		"fileName": "{{fileNameSnakeCase}}_service.py",
		"folder": ""
	},
	"priority": 90,
	"complexity": "low",
	"usage": "common",
	"recommended": true,
	"template": [
		"\"\"\"{{fileNamePascalCase}}Service",
		"",
		"Service layer for {{fileNameSnakeCase}} use cases.",
		"Generated on {{date}} by {{author}}",
		"\"\"\"",
		"",
		"from typing import Any",
		"",
		"",
		"class {{fileNamePascalCase}}Service:",
		"    \"\"\"Handles {{fileNameSnakeCase}} business logic.\"\"\"",
		"",
		"    def execute(self, data: dict[str, Any]) -> dict[str, Any]:",
		"        \"\"\"Main use case execution.\"\"\"",
		"        if not data:",
		"            raise ValueError('data must not be empty')",
		"",
		"        return {",
		"            'status': 'ok',",
		"            'input': data,",
		"        }"
	]
}
