{
	"id": "python.cli.tool",
	"name": "Python CLI Tool",
	"description": "CLI utility with argparse and entrypoint",
	"category": "file",
	"subcategory": "cli",
	"tags": ["python", "cli", "argparse"],
	"framework": "none",
	"language": "python",
	"kind": "file",
	"multiFile": false,
	"type": "cli",
	"output": {
		"fileName": "{{fileNameSnakeCase}}_cli.py",
		"folder": ""
	},
	"priority": 80,
	"complexity": "low",
	"usage": "common",
	"recommended": true,
	"template": [
		"\"\"\"{{fileNamePascalCase}} CLI",
		"",
		"Command line interface for {{fileNameSnakeCase}} operations.",
		"Generated on {{date}} by {{author}}",
		"\"\"\"",
		"",
		"import argparse",
		"",
		"",
		"def build_parser() -> argparse.ArgumentParser:",
		"    \"\"\"Build and return the CLI argument parser.\"\"\"",
		"    parser = argparse.ArgumentParser(",
		"        prog='{{fileNameKebabCase}}',",
		"        description='CLI for {{fileNameSentenceCase}}',",
		"    )",
		"    parser.add_argument(",
		"        '--name',",
		"        default='world',",
		"        help='Name to greet',",
		"    )",
		"    return parser",
		"",
		"",
		"def main() -> int:",
		"    \"\"\"CLI entry point.\"\"\"",
		"    parser = build_parser()",
		"    parsed_args = parser.parse_args()",
		"    name = parsed_args.name.strip()",
		"    if not name:",
		"        parser.error('name must not be empty')",
		"",
		"    print(f'Hello, {name}!')",
		"    return 0",
		"",
		"",
		"if __name__ == '__main__':",
		"    raise SystemExit(main())"
	]
}
