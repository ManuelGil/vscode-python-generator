{
  "id": "python.infrastructure.logger",
  "name": "Logger Setup",
  "description": "Structured logger configuration",
  "category": "infrastructure",
  "subcategory": "logging",
  "tags": ["python", "logging", "observability"],
  "framework": "none",
  "language": "python",
  "kind": "file",
  "multiFile": false,
  "type": "logger",
  "output": {
    "fileName": "{{fileNameSnakeCase}}_logger.py",
    "folder": ""
  },
  "priority": 70,
  "complexity": "low",
  "usage": "common",
  "recommended": false,
  "template": [
    "\"\"\"Logging setup for {{fileNamePascalCase}}.\"\"\"",
    "",
    "import logging",
    "",
    "",
    "def configure_logger(name: str = '{{fileNameSnakeCase}}') -> logging.Logger:",
    "    \"\"\"Configure and return a logger instance.\"\"\"",
    "    logger = logging.getLogger(name)",
    "",
    "    if logger.handlers:",
    "        return logger",
    "",
    "    logger.setLevel(logging.INFO)",
    "    formatter = logging.Formatter(",
    "        '%(asctime)s | %(levelname)s | %(name)s | %(message)s',",
    "    )",
    "",
    "    stream_handler = logging.StreamHandler()",
    "    stream_handler.setFormatter(formatter)",
    "",
    "    logger.addHandler(stream_handler)",
    "    logger.propagate = False",
    "    return logger"
  ]
}
