{
	"id": "python.file.script",
	"name": "Python Script",
	"description": "Standalone Python script with main entry point",
	"category": "file",
	"subcategory": "cli",
	"tags": ["python", "script", "entrypoint"],
	"framework": "none",
	"language": "python",
	"kind": "file",
	"multiFile": false,
	"type": "script",
	"output": {
		"fileName": "{{fileNameSnakeCase}}.py",
		"folder": ""
	},
	"priority": 70,
	"complexity": "low",
	"usage": "common",
	"recommended": true,
	"template": [
		"\"\"\"{{fileNamePascalCase}}",
		"",
		"A Python script template with best practices.",
		"Generated on {{date}} by {{author}}",
		"\"\"\"",
		"",
		"import logging",
		"import sys",
		"",
		"logger = logging.getLogger(__name__)",
		"",
		"",
		"def main() -> int:",
		"    \"\"\"Entry point for the script.\"\"\"",
		"    try:",
		"        logger.info('Hello from {{fileName}}')",
		"        return 0",
		"    except KeyboardInterrupt:",
		"        logger.warning('Operation cancelled by user')",
		"        return 130",
		"    except Exception as error:",
		"        logger.exception('Unexpected error')",
		"        return 1",
		"",
		"",
		"if __name__ == '__main__':",
		"    logging.basicConfig(level=logging.INFO, format='%(message)s', stream=sys.stdout)",
		"    raise SystemExit(main())"
	]
}
