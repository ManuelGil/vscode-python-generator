{
	"id": "python.file.module",
	"name": "Python Module",
	"description": "Reusable Python module with class structure",
	"category": "file",
	"subcategory": "domain",
	"tags": ["python", "module", "class"],
	"framework": "none",
	"language": "python",
	"kind": "file",
	"multiFile": false,
	"type": "module",
	"output": {
		"fileName": "{{fileNameSnakeCase}}.py",
		"folder": ""
	},
	"priority": 65,
	"complexity": "low",
	"usage": "common",
	"recommended": false,
	"template": [
		"\"\"\"{{fileNamePascalCase}} Module",
		"",
		"A reusable module template with best practices.",
		"Generated on {{date}} by {{author}}",
		"\"\"\"",
		"",
		"import logging",
		"from typing import Any",
		"",
		"logger = logging.getLogger(__name__)",
		"",
		"",
		"class {{fileNamePascalCase}}:",
		"    \"\"\"{{fileNamePascalCase}} class for managing {{fileNameSnakeCase}} operations.\"\"\"",
		"",
		"    def __init__(self, name: str = '{{fileName}}') -> None:",
		"        \"\"\"Initialize the {{fileNamePascalCase}} instance.\"\"\"",
		"        self.name = name",
		"        self._data: dict[str, Any] = {}",
		"",
		"    def run(self) -> None:",
		"        \"\"\"Execute the main operation.\"\"\"",
		"        logger.info('Running %s...', self.name)",
		"",
		"    def __repr__(self) -> str:",
		"        \"\"\"Return string representation.\"\"\"",
		"        return f'{self.__class__.__name__}(name={self.name!r})'"
	]
}
